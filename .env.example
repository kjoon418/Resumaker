# compose.yaml이 읽는 환경변수 템플릿. 이 파일을 `.env`로 복사해 값을 채운다(.env는 커밋 금지).
#   cp .env.example .env
#
# 로컬에서 AI 생성 기능을 안 쓰면 ANTHROPIC_API_KEY 없이도 계정/경험/목표/양식 CRUD는 동작한다.

# ── AI 생성/양식 해석 인증(아래 둘 중 하나. 둘 다 비우면 AI 생성·양식해석만 503으로 실패; CRUD는 정상) ──
#
# [권장-개발] Claude 구독(Pro/Max) 토큰 — 종량 API 잔액을 쓰지 않는다(개발 중 추가 지출 0).
#   발급: 호스트에서 `claude setup-token` 실행(구독 로그인 필요) → 출력된 토큰(sk-ant-oat...)을 아래에 붙여넣기.
#   주의: 이 토큰을 쓸 땐 ANTHROPIC_API_KEY는 반드시 비워 둔다(키가 있으면 CLI가 종량 API를 택해 잔액을 소비).
CLAUDE_CODE_OAUTH_TOKEN=
#
# [종량] API 키 — 호출량만큼 API 잔액이 차감된다(운영/CI용). 발급: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── DB (로컬은 기본값으로 충분, 배포 시 변경) ──
DB_NAME=resumaker
DB_USERNAME=resumaker
DB_PASSWORD=resumaker
# DB_PORT=5432

# ── Redis (인증 토큰 저장소) ──
# 로컬은 기본값으로 충분. 외부 Redis(관리형·별도 서버) 사용 시 지정.
# REDIS_HOST=redis
# REDIS_PORT=6379

# ── 백엔드 ──
# SERVER_PORT=8082
# CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
# CLAUDE_CLI_MODEL=claude-sonnet-4-5
# CLAUDE_CLI_TIMEOUT=120s

# ── 프론트엔드(nginx 정적 서빙) ──
# FRONTEND_PORT=8081
# 브라우저가 호출할 백엔드 주소. 다른 도메인 배포 시 실제 API 도메인으로 지정(예: https://api.example.com).
# API_BASE=http://localhost:8082
# 대기 시간 광고 슬롯 on/off(baseline 측정 땐 false). 미지정 시 켜짐.
# ADS_ENABLED=true
# AdSense 퍼블리셔 ID(ca-pub-…). 채우면 컨테이너 기동 시 ads.txt·소유권 확인 메타 태그가 자동 생성된다.
# 발급 전까지 비워 둔다(빈 값=AdSense 무동작). 실제 광고는 공개 콘텐츠 표면에 싣는다(docs/광고-AdSense-전략.md).
# ADSENSE_CLIENT=

# ── 배포: 외부 DB나 레지스트리 이미지를 쓸 때 ──
# DB_URL=jdbc:postgresql://db.example.com:5432/resumaker
# BACKEND_IMAGE=registry.example.com/resumaker-backend:1.0.0
# FRONTEND_IMAGE=registry.example.com/resumaker-frontend:1.0.0
