# compose.yaml이 읽는 환경변수 템플릿. 이 파일을 `.env`로 복사해 값을 채운다(.env는 커밋 금지).
#   cp .env.example .env
#
# 로컬에서 AI 생성 기능을 안 쓰면 ANTHROPIC_API_KEY 없이도 계정/경험/목표/양식 CRUD는 동작한다.

# ── AI 생성/양식 해석(필수: 이력서/포트폴리오 자동 생성을 쓰려면) ──
ANTHROPIC_API_KEY=

# ── DB (로컬은 기본값으로 충분, 배포 시 변경) ──
DB_NAME=resumaker
DB_USERNAME=resumaker
DB_PASSWORD=resumaker
# DB_PORT=5432

# ── 백엔드 ──
# SERVER_PORT=8082
# CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
# CLAUDE_CLI_MODEL=claude-sonnet-4-5
# CLAUDE_CLI_TIMEOUT=120s

# ── 프론트엔드(nginx 정적 서빙) ──
# FRONTEND_PORT=8081
# 브라우저가 호출할 백엔드 주소. 다른 도메인 배포 시 실제 API 도메인으로 지정(예: https://api.example.com).
# API_BASE=http://localhost:8082

# ── 배포: 외부 DB나 레지스트리 이미지를 쓸 때 ──
# DB_URL=jdbc:postgresql://db.example.com:5432/resumaker
# BACKEND_IMAGE=registry.example.com/resumaker-backend:1.0.0
# FRONTEND_IMAGE=registry.example.com/resumaker-frontend:1.0.0
