# 배포(VM)용 환경변수 템플릿. VM에서 이 파일을 .env.prod로 복사해 값을 채운다(.env.prod는 커밋 금지).
#   cp .env.prod.example .env.prod
#
# compose.yaml + compose.prod.yaml과 함께 쓴다:
#   docker compose -f compose.yaml -f compose.prod.yaml --env-file .env.prod up -d --no-build

# ── Artifact Registry 이미지(cloudbuild.yaml 산출물). <PROJECT_ID>를 실제 값으로 바꾼다 ──
BACKEND_IMAGE=us-central1-docker.pkg.dev/<PROJECT_ID>/resumaker/backend:latest
FRONTEND_IMAGE=us-central1-docker.pkg.dev/<PROJECT_ID>/resumaker/frontend:latest

# ── DB (운영 비밀번호는 반드시 강한 값으로 교체) ──
DB_NAME=resumaker
DB_USERNAME=resumaker
DB_PASSWORD=__강한_비밀번호로_교체__

# ── AI 호출: 운영은 Anthropic API 직접 호출(claude CLI 프로세스 미사용 → e2-micro 메모리 부담 0) ──
# LLM_PROVIDER=api면 종량 API 키로 Messages API를 직접 부른다(구독 토큰 불가). 로컬은 기본값 cli(구독 토큰, 비용 0).
LLM_PROVIDER=api
ANTHROPIC_API_KEY=__console.anthropic.com에서_발급한_키__
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CLI_MODEL=claude-sonnet-4-5
CLAUDE_CLI_TIMEOUT=120s
# 응답 출력 토큰 상한(구조화 결과가 잘리면 키운다). 기본 16000.
ANTHROPIC_MAX_TOKENS=16000

# ── 도메인/CORS (Cloudflare Tunnel의 Public Hostname과 일치시킨다) ──
# 프론트가 브라우저에서 호출할 백엔드 주소.
API_BASE=https://api.<도메인>
# 쿠키 인증을 위해 프론트 오리진만 허용(SameSite=None; Secure는 HTTPS라 충족).
CORS_ALLOWED_ORIGINS=https://app.<도메인>

# ── 광고 / AdSense (docs/광고-AdSense-전략.md) ──
# 대기 시간 광고 슬롯 on/off. baseline 측정 기간엔 false로 두고, 이후 true. 미지정 시 켜짐.
# ADS_ENABLED=true
# AdSense 퍼블리셔 ID. 발급 후 채우면 https://app.<도메인>/ads.txt 와 소유권 확인 메타 태그가 자동 생성된다(소유권 확인용).
# 발급 전까지 비워 둔다. 실제 광고 유닛은 공개 콘텐츠 표면에 별도로 싣는다.
# ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# 공개 콘텐츠 표면(/guide, /about, /privacy)의 절대 URL 기준(프런트 공개 도메인). canonical·sitemap·robots에 박힌다.
SITE_ORIGIN=https://app.<도메인>

# ── Cloudflare Tunnel 토큰(Zero Trust 대시보드에서 발급) ──
TUNNEL_TOKEN=__cloudflare_tunnel_token__

# ── e2-micro(RAM 1GB) JVM 힙 가드. OOM이 잦으면 더 낮추거나 e2-small로 상향 ──
JAVA_TOOL_OPTIONS=-Xmx320m -XX:MaxMetaspaceSize=128m
